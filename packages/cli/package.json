    "@batonpass/adapter-codex": "workspace:*",
    "commander": "^12.1.0",
    "node-pty": "^1.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
