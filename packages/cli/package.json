{
  "name": "batonpass",
  "version": "0.1.0",
  "description": "Batonpass: automatic session handoff for coding agents (Claude Code, Codex).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "batonpass": "./dist/index.js" },
